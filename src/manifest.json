{
  "manifest_version": 3,
  "name": "PromptDeck",
  "short_name": "PromptDeck",
  "description": "Local-first prompt launcher for reusable AI prompts in any text field.",
  "version": "0.1.0",
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "src/popup/index.html",
    "default_title": "PromptDeck"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "options_page": "src/options/index.html",
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": [],
  "commands": {
    "open-promptdeck": {
      "suggested_key": {
        "default": "Ctrl+K",
        "mac": "Command+K"
      },
      "description": "Open PromptDeck prompt library"
    }
  }
}
