{
  "name": "promptdeck-vscode",
  "displayName": "PromptDeck",
  "description": "Local-first prompt library inside VS Code — search, insert, and copy reusable prompts from the same library as the PromptDeck CLI.",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "promptdeck",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      { "command": "promptdeck.openManager", "title": "PromptDeck: Open Manager" },
      { "command": "promptdeck.searchPrompt", "title": "PromptDeck: Search Prompt" },
      { "command": "promptdeck.insertPrompt", "title": "PromptDeck: Insert Prompt" },
      { "command": "promptdeck.copyPrompt", "title": "PromptDeck: Copy Prompt" },
      { "command": "promptdeck.newPrompt", "title": "PromptDeck: New Prompt" },
      { "command": "promptdeck.editPrompt", "title": "PromptDeck: Edit Prompt" },
      { "command": "promptdeck.duplicatePrompt", "title": "PromptDeck: Duplicate Prompt" },
      { "command": "promptdeck.deletePrompt", "title": "PromptDeck: Delete Prompt" },
      { "command": "promptdeck.importBackup", "title": "PromptDeck: Import Backup" },
      { "command": "promptdeck.exportBackup", "title": "PromptDeck: Export Backup" },
      { "command": "promptdeck.openLibraryFile", "title": "PromptDeck: Open Library File" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "promptdeck",
          "title": "PromptDeck",
          "icon": "resources/promptdeck.svg"
        }
      ]
    },
    "views": {
      "promptdeck": [
        {
          "id": "promptdeck.prompts",
          "name": "Prompts"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "promptdeck.openManager",
          "when": "view == promptdeck.prompts",
          "group": "navigation@0"
        },
        {
          "command": "promptdeck.newPrompt",
          "when": "view == promptdeck.prompts",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "promptdeck.editPrompt",
          "when": "view == promptdeck.prompts && viewItem == prompt",
          "group": "inline"
        },
        {
          "command": "promptdeck.duplicatePrompt",
          "when": "view == promptdeck.prompts",
          "group": "inline"
        },
        {
          "command": "promptdeck.deletePrompt",
          "when": "view == promptdeck.prompts",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "PromptDeck",
      "properties": {
        "promptdeck.libraryPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the PromptDeck library file. Leave empty to use the default (~/.promptdeck/library.json or PROMPTDECK_LIBRARY/PROMPTDECK_HOME)."
        }
      }
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc -p .",
    "vscode:prepublish": "node scripts/build.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.19.40",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.5"
  }
}
